# Variáveis usadas pelo docker-compose.yml na raiz do projeto.
# Copie para ".env" (na raiz) e ajuste se necessário:
#   cp .env.example .env

# ===== Banco de Dados (PostgreSQL) =====
DB_NAME=biblioteca
DB_USER=biblioteca
DB_PASS=biblioteca
DB_PORT=5432

# Sincronização do Sequelize: none | alter | force
DB_SYNC=alter

# ===== JWT =====
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=1d

# ===== Seed (usuário administrador inicial) =====
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@biblioteca.com
ADMIN_PASSWORD=admin123

# ===== CORS (API) =====
CORS_ORIGIN=*

# ===== Portas expostas no host =====
API_PORT=3000
WEB_PORT=8080

# URL que o frontend usa para chamar a API (build-time).
# Padrão "/api" funciona porque o Nginx do frontend faz proxy para a API.
VITE_API_URL=/api
