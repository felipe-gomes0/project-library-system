# ===== Servidor =====
PORT=3000
NODE_ENV=development

# ===== Banco de Dados (PostgreSQL) =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=biblioteca
DB_USER=biblioteca
DB_PASS=biblioteca

# Sincronização do Sequelize com o banco:
#   none  -> não altera tabelas (use migrations)
#   alter -> ajusta tabelas para os models (padrão em dev)
#   force -> DROPA e recria todas as tabelas (apaga dados!)
DB_SYNC=alter

# ===== JWT =====
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=1d

# ===== Seed (usuário administrador inicial) =====
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@biblioteca.com
ADMIN_PASSWORD=admin123

# ===== CORS =====
CORS_ORIGIN=*
